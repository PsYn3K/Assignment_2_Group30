extends layout

block content
  
  h1 Login Page

  if error
    p= error

  div#formErrors

  form#loginForm(action="/login" method="POST")
    label(for="email") Email:
    input(type="text" name="email" id="email")
    br

    label(for="password") Password:
    input(type="password" name="password" id="password")
    br

    button(type="submit") Login