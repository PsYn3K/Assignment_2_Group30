doctype html
html
  head
    title Edit Task
    link(rel="stylesheet" href="/styles.css")

  body
    h1 Edit Task

    form(action=`/edit-task/${task._id}` method="POST")
      input(type="text" name="title" value=task.title)
      button(type="submit") Update Task

    br
    a(href="/dashboard") Back to Dashboard