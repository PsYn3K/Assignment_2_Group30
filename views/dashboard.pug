extends layout  

block content 

  h1 Welcome #{user.username}

  a(href="/logout") Logout

  h2 Add Vibe
  form(action="/add-vibe" method="POST")
    input(type="text" name="vibeName" placeholder="Enter vibe name")
    button(type="submit") Add

  h2 Search Vibes
  form(action="/dashboard" method="GET")
    input(type="text" name="search" placeholder="Search vibes" value=search)
    button(type="submit") Search

  h2 Your Vibes
  if Vibe.length === 0
    p No vibes found.
  ul
    each vibe in Vibe
      li
        | #{vibe.vibeName}
        a(href=`/edit-vibe/${vibe._id}` style="margin-left:10px;") Edit
        form(action=`/delete-vibe/${vibe._id}` method="POST" style="display:inline; margin-left:10px;")
          button(type="submit") Delete